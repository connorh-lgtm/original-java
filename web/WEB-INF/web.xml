<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>Legacy RealWorld Blog API</display-name>
    <description>
        A legacy servlet-based blog API. No Spring, no dependency injection,
        just raw servlets and XML configuration.
    </description>

    <!-- ============================================================ -->
    <!-- Listeners                                                      -->
    <!-- ============================================================ -->
    <listener>
        <listener-class>com.legacy.realworld.AppInitializer</listener-class>
    </listener>
    <listener>
        <listener-class>com.legacy.realworld.util.AppContextListener</listener-class>
    </listener>

    <!-- ============================================================ -->
    <!-- Filters                                                        -->
    <!-- ============================================================ -->
    <filter>
        <filter-name>AuthenticationFilter</filter-name>
        <filter-class>com.legacy.realworld.filter.AuthenticationFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/api/*</url-pattern>
    </filter-mapping>

    <!-- ============================================================ -->
    <!-- Servlet Declarations                                          -->
    <!-- TODO: Consider using annotation-based configuration (@WebServlet) -->
    <!-- But we've "always done it this way" so let's keep web.xml     -->
    <!-- ============================================================ -->

    <!-- Article Servlet -->
    <servlet>
        <servlet-name>ArticleServlet</servlet-name>
        <servlet-class>com.legacy.realworld.servlet.ArticleServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>ArticleServlet</servlet-name>
        <url-pattern>/api/articles/*</url-pattern>
    </servlet-mapping>

    <!-- User Servlet -->
    <servlet>
        <servlet-name>UserServlet</servlet-name>
        <servlet-class>com.legacy.realworld.servlet.UserServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserServlet</servlet-name>
        <url-pattern>/api/users/*</url-pattern>
    </servlet-mapping>

    <!-- Comment Servlet -->
    <!-- NOTE: Comments are accessed via /api/articles/{slug}/comments but the
         Servlet spec only supports wildcards at the end of a path prefix.
         So CommentServlet is mapped to /api/comments/* and we use the
         article slug as a path component: /api/comments/{slug} and /api/comments/{slug}/{id}
         The ArticleServlet at /api/articles/* handles forwarding requests that
         contain /comments/ in the path to this servlet via RequestDispatcher. -->
    <!-- TODO: This two-servlet routing hack is fragile. A front-controller
         pattern or a framework like Spring MVC would handle this cleanly. -->
    <servlet>
        <servlet-name>CommentServlet</servlet-name>
        <servlet-class>com.legacy.realworld.servlet.CommentServlet</servlet-class>
        <load-on-startup>1</load-on-startup>
    </servlet>
    <servlet-mapping>
        <servlet-name>CommentServlet</servlet-name>
        <url-pattern>/api/comments/*</url-pattern>
    </servlet-mapping>


    <!-- Session configuration -->
    <session-config>
        <!-- 30 minute timeout -->
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- Welcome file list -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Error pages - at least we have these -->
    <error-page>
        <error-code>404</error-code>
        <location>/error/404.html</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/error/500.html</location>
    </error-page>

</web-app>
